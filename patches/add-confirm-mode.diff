 static volatile sig_atomic_t g_interrupt = 0;
 static int g_debug = 0;
+static int g_allow_shell = 0, g_allow_edit = 0;
+static FILE *g_tty = NULL;
 static void on_sigint(int sig) { (void)sig; g_interrupt = 1; }
 
+static int confirm_tool(const char *name, const char *preview) {
+    if (getenv("SA_NO_CONFIRM")) return 1;
+    if (strcmp(name, "shell") == 0 && g_allow_shell) return 1;
+    if (strcmp(name, "edit_file") == 0 && g_allow_edit) return 1;
+    if (!g_tty) g_tty = fopen("/dev/tty", "r+");
+    if (!g_tty) { fprintf(stderr, "\n[confirm] no tty, denying %s (set SA_NO_CONFIRM=1 to skip)\n", name); return 0; }
+    for (;;) {
+        fprintf(g_tty, "\n\x1b[33m[%s]\x1b[0m %s\napprove? [y]es / [n]o / [a]lways: ", name, preview);
+        fflush(g_tty);
+        char line[16];
+        if (!fgets(line, sizeof line, g_tty)) return 0;
+        switch (line[0]) {
+            case 'y': case 'Y': case '\n': return 1;
+            case 'n': case 'N': return 0;
+            case 'a': case 'A':
+                if (strcmp(name, "shell") == 0) g_allow_shell = 1;
+                else if (strcmp(name, "edit_file") == 0) g_allow_edit = 1;
+                return 1;
+        }
+    }
+}
